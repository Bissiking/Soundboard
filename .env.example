# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_guild_id_for_dev

# Bot Web Control (utilisés par le bouton Connect de l'interface)
DEFAULT_GUILD_ID=your_guild_id
DEFAULT_VOICE_CHANNEL_ID=your_voice_channel_id
BOT_AUTO_DISCONNECT_MS=120000

# API
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luma_soundboard
DB_USER=postgres
DB_PASSWORD=your_password

# Stockage
UPLOADS_DIR=./uploads/sounds
MAX_FILE_SIZE_MB=1
MAX_DURATION_SEC=10
